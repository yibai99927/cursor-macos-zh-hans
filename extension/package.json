{
  "name": "cursor-zh-hans-guard",
  "displayName": "Cursor 简体中文守护",
  "description": "检测 Cursor 更新后汉化补丁是否丢失，并尝试自动回补静态补丁",
  "version": "0.3.0",
  "publisher": "cursor-zh-local",
  "license": "MIT",
  "engines": {
    "vscode": "^1.80.0"
  },
  "extensionKind": ["ui"],
  "activationEvents": ["onStartupFinished"],
  "main": "./extension.js",
  "contributes": {
    "commands": [
      {
        "command": "cursorZhHans.checkPatchStatus",
        "title": "Cursor 简体中文: 检查汉化状态"
      },
      {
        "command": "cursorZhHans.reapplyStaticPatch",
        "title": "Cursor 简体中文: 尝试回补静态补丁"
      },
      {
        "command": "cursorZhHans.openInstallGuide",
        "title": "Cursor 简体中文: 打开重装说明"
      }
    ],
    "configuration": {
      "title": "Cursor 简体中文守护",
      "properties": {
        "cursorZhHans.autoReapplyStaticPatch": {
          "type": "boolean",
          "default": true,
          "description": "启动时若检测到静态补丁丢失，尝试自动回补（需对 Cursor 安装目录有写权限）"
        },
        "cursorZhHans.cursorAppRoot": {
          "type": "string",
          "default": "",
          "description": "手动指定 Cursor 的 resources/app 目录；留空则自动检测"
        }
      }
    }
  },
  "categories": ["Other"]
}
