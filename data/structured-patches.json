{
  "version": "1.2.0",
  "description": "按对象字面量 key 锚定替换硬编码文案（比整段压缩串更抗更新）。思路参考 YeYu-Wang/cursor-zh-hans-language-pack（MIT）。",
  "targets": [
    {
      "file": "out/vs/workbench/workbench.glass.main.js",
      "required": true
    },
    {
      "file": "out/vs/workbench/workbench.desktop.main.js",
      "required": false
    },
    {
      "file": "out/vs/workbench/workbench.anysphere-ui-automations.js",
      "required": false
    }
  ],
  "structuredReplacements": [
    {
      "id": "settings-nav-labels",
      "type": "object-literal-values",
      "description": "Cursor 设置侧栏主导航",
      "optional": true,
      "requiredKeys": [
        "general",
        "vscode-settings",
        "plan-usage",
        "chat",
        "models",
        "rules",
        "mcp",
        "background-composer"
      ],
      "values": {
        "general": { "source": "General", "target": "通用" },
        "profile": { "source": "Profile", "target": "个人资料" },
        "vscode-settings": { "source": "VS Code Settings", "target": "VS Code 设置" },
        "appearance": { "source": "Appearance", "target": "外观" },
        "fun": { "source": "Fun", "target": "趣味" },
        "plan-usage": { "source": "Plan & Usage", "target": "套餐与用量" },
        "chat": { "source": "Agents", "target": "Agent" },
        "browser": { "source": "Browser & Network", "target": "浏览器与网络" },
        "tab": { "source": "Tab", "target": "Tab 补全" },
        "models": { "source": "Models", "target": "模型" },
        "git-prs": { "source": "Git & PRs", "target": "Git 与 PR" },
        "rules": { "source": "Rules, Skills, Subagents", "target": "规则、技能与子 Agent" },
        "plugins": { "source": "Plugins", "target": "插件" },
        "customize": { "source": "Customize", "target": "自定义" },
        "indexing": { "source": "Indexing & Docs", "target": "索引与文档" },
        "mcp": { "source": "Tools & MCPs", "target": "工具与 MCP" },
        "hooks": { "source": "Hooks", "target": "钩子" },
        "beta": { "source": "Beta", "target": "测试版" },
        "network": { "source": "Network", "target": "网络" },
        "background-composer": { "source": "Cloud Agents", "target": "云端 Agent" },
        "self-driving": { "source": "Self-driving PRs", "target": "自动驾驶 PR" },
        "worktrees": { "source": "Worktrees", "target": "工作树" },
        "developer": { "source": "Developer", "target": "开发者" }
      }
    },
    {
      "id": "browser-settings-labels",
      "type": "object-literal-values",
      "description": "浏览器设置文案（用更稳定的长 key 锚定，避免 section/automation 等泛词误判）",
      "optional": true,
      "requiredKeys": [
        "protectionDescription",
        "showLocalhostLinks",
        "openWebLinks"
      ],
      "values": {
        "section": { "source": "Browser", "target": "浏览器" },
        "automation": { "source": "Browser Automation", "target": "浏览器自动化" },
        "protection": { "source": "Browser Protection", "target": "浏览器保护" },
        "protectionDescription": {
          "source": "Prevent Agent from automatically running Browser tools",
          "target": "阻止 Agent 自动运行浏览器工具"
        },
        "showLocalhostLinks": {
          "source": "Show Localhost Links in Browser",
          "target": "在浏览器中显示 Localhost 链接"
        },
        "openWebLinks": {
          "source": "Open Web Links in Browser",
          "target": "在浏览器中打开网页链接"
        }
      }
    }
  ]
}
